<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FF1A1A2E">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <com.google.android.material.appbar.MaterialToolbar
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="#FF16213E"
            android:title="WiFi Analyzer Pro"
            android:titleTextColor="#FFFFFFFF" />

        <TextView
            android:id="@+id/textNetworkCount"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Scanning..."
            android:textColor="#FF0F3460"
            android:textSize="15sp"
            android:padding="12dp" />

        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#FF533483" />

        <TextView
            android:id="@+id/textConnection"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Connecting..."
            android:textColor="#FFE94560"
            android:textSize="14sp"
            android:padding="12dp"
            android:lineSpacingExtra="3dp" />

        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#FF533483" />

        <TextView
            android:id="@+id/textSpeed"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Measuring speed..."
            android:textColor="#FFE94560"
            android:textSize="14sp"
            android:padding="12dp" />

        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#FF533483" />

        <TextView
            android:id="@+id/textChannels"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Analyzing channels..."
            android:textColor="#FF0F3460"
            android:textSize="14sp"
            android:padding="12dp" />

        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#FF533483" />

        <TextView
            android:id="@+id/textDiag"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Running diagnostics..."
            android:textColor="#FFE94560"
            android:textSize="13sp"
            android:padding="12dp" />

        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#FF533483" />

        <TextView
            android:id="@+id/textSubnet"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Calculating subnet..."
            android:textColor="#FF0F3460"
            android:textSize="13sp"
            android:padding="12dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnScan"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="16dp"
            android:text="Scan Again"
            android:backgroundTint="#FF533483" />

    </LinearLayout>
</ScrollView>
